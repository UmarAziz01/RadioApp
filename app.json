{
  "expo": {
    "name": "Radio App",
    "slug": "radio-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled":true,
    "splash": {
      "image": "./assets/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet":true,
      "bundleIdentifier": "com.radioapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Agar aplikasi dapat merekam audio dari mikrofon."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.radioapp",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-sharing"
    ]
  }
}