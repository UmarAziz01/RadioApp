# ============================================
# Cloudflare Workers / Pages Deployment
# ============================================

# Cloudflare API Token
# Buat di: https://dash.cloudflare.com/profile/api-tokens
# Pilih template "Edit Cloudflare Workers" atau buat custom token dengan permissions:
#   - Account > Cloudflare Pages > Edit
#   - Account > Cloudflare Workers Scripts > Edit
#   - Zone > Zone > Read (opsional, jika pakai custom domain)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Account ID
# Temukan di: https://dash.cloudflare.com → pilih domain → scroll ke bawah di bagian "API" sidebar kanan
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ============================================
# Cara Setup di GitHub Repository Secrets
# ============================================
# 1. Buka https://github.com/UmarAziz01/RadioApp/settings/secrets/actions
# 2. Klik "New repository secret"
# 3. Tambahkan:
#    - Name: CLOUDFLARE_API_TOKEN    → Value: (paste API token kamu)
#    - Name: CLOUDFLARE_ACCOUNT_ID   → Value: (paste Account ID kamu)
# 4. Setelah push ke branch main, GitHub Actions akan otomatis build & deploy